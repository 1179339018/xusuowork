/* 文章场景相关 */
.container {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding: 20rpx;
}

/* 派出所视图 */
.police-view .action-card {
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(22, 119, 255, 0.2);
}
.police-view .action-card .btn-primary {
  background: rgba(255, 255, 255, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  color: #fff;
  border-radius: 8rpx;
  padding: 15rpx 0;
  font-size: 32rpx;
  font-weight: 600;
}
.police-view .action-card .btn-primary .icon-plus {
  font-size: 40rpx;
  margin-right: 10rpx;
}
.police-view .stats-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  text-align: center;
}
.police-view .stats-card.highlight {
  background: linear-gradient(135deg, #faad14 0%, #ffc53d 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(250, 173, 20, 0.2);
}
.police-view .stats-card .stats-title {
  font-size: 28rpx;
  color: #64748b;
  margin-bottom: 10rpx;
}
.highlight .police-view .stats-card .stats-title {
  color: rgba(255, 255, 255, 0.9);
}
.police-view .stats-card .stats-value {
  font-size: 64rpx;
  font-weight: bold;
  color: #1e293b;
  margin-bottom: 10rpx;
}
.highlight .police-view .stats-card .stats-value {
  color: #fff;
}
.police-view .stats-card .stats-desc {
  font-size: 24rpx;
  color: #94a3b8;
}
.highlight .police-view .stats-card .stats-desc {
  color: rgba(255, 255, 255, 0.8);
}

/* 街道视图 */
.street-view .stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 20rpx;
}
.street-view .stats-grid .stats-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 25rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  text-align: center;
}
.street-view .stats-grid .stats-card .stats-title {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 10rpx;
}
.street-view .stats-grid .stats-card .stats-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #1e293b;
}
.street-view .action-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}
.street-view .action-card .btn-primary {
  background: #1677ff;
  color: #fff;
  border-radius: 8rpx;
  padding: 15rpx 0;
  font-size: 28rpx;
  font-weight: 500;
}

/* 社区视图 */
.community-view .stats-card {
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(82, 196, 26, 0.2);
  text-align: center;
  color: #fff;
}
.community-view .stats-card .stats-title {
  font-size: 28rpx;
  margin-bottom: 10rpx;
}
.community-view .stats-card .stats-value {
  font-size: 64rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}
.community-view .stats-card .stats-desc {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 管理员视图 */
.admin-view .stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 20rpx;
}
.admin-view .stats-grid .stats-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 25rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  text-align: center;
}
.admin-view .stats-grid .stats-card .stats-title {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 10rpx;
}
.admin-view .stats-grid .stats-card .stats-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #1e293b;
}
.admin-view .admin-actions {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}
.admin-view .admin-actions .action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 20rpx;
}
.admin-view .admin-actions .action-grid .action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  cursor: pointer;
  transition: all 0.3s ease;
}
.admin-view .admin-actions .action-grid .action-item:hover {
  background: #e6f7ff;
  transform: translateY(-2rpx);
}
.admin-view .admin-actions .action-grid .action-item .action-icon {
  font-size: 64rpx;
  margin-bottom: 10rpx;
}
.admin-view .admin-actions .action-grid .action-item .action-text {
  font-size: 24rpx;
  color: #64748b;
}
.admin-view .export-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}
.admin-view .export-section .export-form .form-row {
  margin-bottom: 20rpx;
}
.admin-view .export-section .export-form .form-row .form-label {
  font-size: 28rpx;
  color: #1e293b;
  margin-bottom: 10rpx;
  font-weight: 500;
}
.admin-view .export-section .export-form .form-row .picker-input {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f5f7fa;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #1e293b;
}
.admin-view .export-section .export-form .form-row .picker-input .arrow {
  font-size: 32rpx;
  color: #94a3b8;
}
.admin-view .export-section .export-form .form-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}
.admin-view .export-section .export-form .form-actions button {
  flex: 1;
  padding: 15rpx 0;
  font-size: 28rpx;
  font-weight: 500;
}
.admin-view .export-section .export-form .form-actions .btn-primary {
  background: #1677ff;
  color: #fff;
  border-radius: 8rpx;
}
.admin-view .export-section .export-form .form-actions .btn-secondary {
  background: #f5f7fa;
  color: #64748b;
  border-radius: 8rpx;
  border: 1rpx solid #e2e8f0;
}

/* 最近列表 */
.recent-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}
.recent-list .section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1e293b;
  margin-bottom: 20rpx;
}
.recent-list .list-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
  cursor: pointer;
  transition: all 0.3s ease;
}
.recent-list .list-item:last-child {
  border-bottom: none;
}
.recent-list .list-item:hover {
  background: #f8fafc;
  padding-left: 10rpx;
}
.recent-list .list-item .item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}
.recent-list .list-item .item-header .item-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1e293b;
  flex: 1;
  margin-right: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.recent-list .list-item .item-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.recent-list .list-item .item-info .item-time {
  font-size: 24rpx;
  color: #94a3b8;
}
.recent-list .list-item .item-info .item-from {
  font-size: 24rpx;
  color: #64748b;
}
.recent-list .list-item .item-info .status-text {
  font-size: 24rpx;
  font-weight: 500;
}
.recent-list .list-item .item-info .status-text.pending {
  color: #faad14;
}
.recent-list .list-item .item-info .status-text.processing {
  color: #1677ff;
}
.recent-list .list-item .item-info .status-text.resolved {
  color: #52c41a;
}
.recent-list .list-item .item-info .status-text.closed {
  color: #94a3b8;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  text-align: center;
}
.empty .empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}
.empty .empty-text {
  font-size: 28rpx;
  color: #94a3b8;
  margin-bottom: 10rpx;
}
.empty .empty-subtext {
  font-size: 24rpx;
  color: #cbd5e1;
}
.empty .login-btn {
  margin-top: 30rpx;
  padding: 15rpx 40rpx;
  background: #1677ff;
  color: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
}

/* 标签 */
.tag {
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 500;
}
.tag.tag-primary {
  background: #e6f7ff;
  color: #1677ff;
}
.tag.tag-danger {
  background: #fff1f0;
  color: #ff4d4f;
}
.tag.tag-warning {
  background: #fff7e6;
  color: #faad14;
}

/* 动画 */
.fade-in {
  animation: fadeIn 0.5s ease-in-out;
}
@keyframes fadeIn {
from {
    opacity: 0;
    transform: translateY(20rpx);
}
to {
    opacity: 1;
    transform: translateY(0);
}
}