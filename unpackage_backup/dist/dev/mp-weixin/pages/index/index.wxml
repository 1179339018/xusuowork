<view class="container"><view wx:if="{{a}}" class="police-view"><view class="action-card"><button class="btn-primary btn-large" bindtap="{{b}}"><text class="icon-plus">+</text><text>新增纠纷</text></button></view><view class="stats-card"><view class="stats-title">今日推送</view><view class="stats-value">{{c}}</view><view class="stats-desc">条纠纷已推送至街道</view></view><view wx:if="{{d}}" class="stats-card highlight"><view class="stats-title">待处理</view><view class="stats-value">{{e}}</view><view class="stats-desc">条社区转办的纠纷</view></view><view class="recent-list"><view class="section-title">最近推送</view><view wx:for="{{f}}" wx:for-item="item" wx:key="f" class="list-item fade-in" bindtap="{{item.g}}"><view class="item-header"><text class="item-title">{{item.a}}</text><text class="tag tag-primary">{{item.b}}</text></view><view class="item-info"><text class="item-time">{{item.c}}</text><text class="{{['status-text', item.e]}}">{{item.d}}</text></view></view><view wx:if="{{g}}" class="empty"><text class="empty-icon">📭</text><text class="empty-text">暂无推送记录</text></view></view></view><view wx:elif="{{h}}" class="street-view"><view class="stats-grid"><view class="stats-card"><view class="stats-title">待分派</view><view class="stats-value">{{i}}</view></view><view class="stats-card"><view class="stats-title">已化解</view><view class="stats-value">{{j}}</view></view><view class="stats-card"><view class="stats-title">化解率</view><view class="stats-value">{{k}}%</view></view></view><view class="action-card"><button class="btn-primary" bindtap="{{l}}"><text>管理纠纷</text></button></view><view class="recent-list"><view class="section-title">待分派纠纷</view><view wx:for="{{m}}" wx:for-item="item" wx:key="f" class="list-item fade-in" bindtap="{{item.g}}"><view class="item-header"><text class="item-title">{{item.a}}</text><text wx:if="{{item.b}}" class="tag tag-danger">特急</text><text wx:elif="{{item.c}}" class="tag tag-warning">紧急</text></view><view class="item-info"><text class="item-time">{{item.d}}</text><text class="status-text pending">{{item.e}}</text></view></view><view wx:if="{{n}}" class="empty"><text class="empty-icon">✅</text><text class="empty-text">暂无待分派纠纷</text></view></view></view><view wx:elif="{{o}}" class="community-view"><view class="stats-card"><view class="stats-title">待回访</view><view class="stats-value">{{p}}</view><view class="stats-desc">条任务需要回访</view></view><view class="recent-list"><view class="section-title">最近任务</view><view wx:for="{{q}}" wx:for-item="item" wx:key="e" class="list-item fade-in" bindtap="{{item.f}}"><view class="item-header"><text class="item-title">{{item.a}}</text><text class="tag tag-primary">{{item.b}}</text></view><view class="item-info"><text class="item-time">{{item.c}}</text><text class="item-from">来自：{{item.d}}</text></view></view><view wx:if="{{r}}" class="empty"><text class="empty-icon">😌</text><text class="empty-text">暂无任务</text></view></view></view><view wx:elif="{{s}}" class="admin-view"><view class="stats-grid"><view class="stats-card"><view class="stats-title">纠纷总数</view><view class="stats-value">{{t}}</view></view><view class="stats-card"><view class="stats-title">已化解</view><view class="stats-value">{{v}}</view></view><view class="stats-card"><view class="stats-title">用户数</view><view class="stats-value">{{w}}</view></view></view><view class="admin-actions"><view class="action-grid"><view class="action-item" bindtap="{{x}}"><view class="action-icon">👥</view><view class="action-text">用户管理</view></view><view class="action-item" bindtap="{{y}}"><view class="action-icon">📋</view><view class="action-text">纠纷管理</view></view><view class="action-item" bindtap="{{z}}"><view class="action-icon">📊</view><view class="action-text">数据导出</view></view></view></view><view class="export-section"><view class="section-title">数据导出</view><view class="export-form"><view class="form-row"><text class="form-label">状态筛选</text><picker mode="selector" range="{{B}}" value="{{C}}" bindchange="{{D}}"><view class="picker-input"><text>{{A}}</text><text class="arrow">›</text></view></picker></view><view class="form-row"><text class="form-label">开始日期</text><picker mode="date" bindchange="{{F}}"><view class="picker-input"><text>{{E}}</text><text class="arrow">›</text></view></picker></view><view class="form-row"><text class="form-label">结束日期</text><picker mode="date" bindchange="{{H}}"><view class="picker-input"><text>{{G}}</text><text class="arrow">›</text></view></picker></view><view class="form-actions"><button class="btn-primary" bindtap="{{I}}">导出数据</button><button class="btn-secondary" bindtap="{{J}}">重置</button></view></view></view></view><view wx:elif="{{K}}" class="no-role-view"><view class="empty"><text class="empty-icon">⚠️</text><text class="empty-text">您还没有分配角色</text><text class="empty-subtext">请联系管理员分配角色</text></view></view><view wx:else class="not-login-view"><view class="empty"><text class="empty-icon">🔐</text><text class="empty-text">请先登录</text><navigator url="/pages/login/index" class="login-btn">去登录</navigator></view></view></view>