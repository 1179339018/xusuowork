}
.task-item .task-footer.data-v-35ff9bcb {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}
.task-item .task-footer .task-time.data-v-35ff9bcb {
  font-size: 24rpx;
  color: #999;
}
.task-item .task-action.data-v-35ff9bcb {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}
.task-item .task-action .btn-visit.data-v-35ff9bcb {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
