.container.data-v-35ff9bcb {
  min-height: 100vh;
  background-color: #f5f5f5;
}
.status-tabs.data-v-35ff9bcb {
  display: flex;
  background: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
}
.status-tabs .tab-item.data-v-35ff9bcb {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  position: relative;
  font-size: 28rpx;
  color: #666;
}
.status-tabs .tab-item.active.data-v-35ff9bcb {
  color: #1677ff;
  font-weight: bold;
}
.status-tabs .tab-item.active.data-v-35ff9bcb::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #1677ff;
  border-radius: 2rpx;
}
.status-tabs .tab-item .badge.data-v-35ff9bcb {
  display: inline-block;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  margin-left: 8rpx;
  background: #ff4d4f;
  color: #fff;
  border-radius: 16rpx;
  font-size: 20rpx;
}
.list-container.data-v-35ff9bcb {
  height: calc(100vh - 200rpx);
}
.task-item.data-v-35ff9bcb {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}
.task-item .task-header.data-v-35ff9bcb {
  margin-bottom: 20rpx;
}
.task-item .task-header .task-title-row.data-v-35ff9bcb {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}
.task-item .task-header .task-title-row .task-title.data-v-35ff9bcb {
  flex: 1;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.task-item .task-header .task-source.data-v-35ff9bcb {
  font-size: 24rpx;
  color: #999;
}
.task-item .task-info.data-v-35ff9bcb {
  background: #f9f9f9;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}
.task-item .task-info .info-row.data-v-35ff9bcb {
  display: flex;
  margin-bottom: 10rpx;
  font-size: 26rpx;
}
.task-item .task-info .info-row.data-v-35ff9bcb:last-child {
  margin-bottom: 0;
}
.task-item .task-info .info-row .info-label.data-v-35ff9bcb {
  color: #666;
  width: 140rpx;
}
.task-item .task-info .info-row .info-value.data-v-35ff9bcb {
