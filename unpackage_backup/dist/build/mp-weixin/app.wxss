page{background:#e6f2ff;font-size:28rpx;color:#1e293b;font-family:-apple-system,BlinkMacSystemFont,Segoe UI,PingFang SC,Hiragino Sans GB,Microsoft YaHei,sans-serif;line-height:1.6}:root{--primary: #1677ff;--primary-light: #4096ff;--primary-dark: #0958d9;--success: #52c41a;--warning: #faad14;--danger: #ff4d4f;--info: #1677ff;--bg: #e6f2ff;--bg-card: #f0f7ff;--text-primary: #1e293b;--text-secondary: #64748b;--text-tertiary: #94a3b8;--border: #e2e8f0;--shadow-sm: 0 1px 3px rgba(0, 0, 0, .05);--shadow-md: 0 4px 12px rgba(0, 0, 0, .08);--shadow-lg: 0 10px 30px rgba(0, 0, 0, .12);--radius-sm: 8rpx;--radius-md: 16rpx;--radius-lg: 32rpx;--radius-xl: 48rpx}.primary-color{color:var(--primary)}.primary-bg{background:linear-gradient(135deg,var(--primary) 0%,var(--primary-light) 100%);color:#fff}.btn-primary{background:linear-gradient(135deg,var(--primary) 0%,var(--primary-light) 100%);color:#fff;border-radius:var(--radius-md);padding:24rpx 48rpx;font-size:30rpx;font-weight:600;border:none;box-shadow:var(--shadow-sm);transition:all .3s ease;position:relative;overflow:hidden}.btn-primary:before{content:"";position:absolute;top:50%;left:50%;width:0;height:0;border-radius:50%;background:rgba(255,255,255,.3);transform:translate(-50%,-50%);transition:width .6s,height .6s}.btn-primary:active{transform:scale(.98);box-shadow:none}.btn-primary:active:before{width:300rpx;height:300rpx}.btn-secondary{background:var(--bg-card);color:var(--primary);border:2rpx solid var(--primary);border-radius:var(--radius-md);padding:24rpx 48rpx;font-size:30rpx;font-weight:600;box-shadow:var(--shadow-sm)}.btn-secondary:active{background:#f0f7ff;transform:scale(.98)}.card{background:var(--bg-card);border-radius:var(--radius-lg);padding:32rpx;margin:24rpx;box-shadow:var(--shadow-md);border:1rpx solid var(--border);transition:all .3s ease}.card:hover{box-shadow:var(--shadow-lg);transform:translateY(-2rpx)}.list-item{background:var(--bg-card);padding:32rpx;border-radius:var(--radius-md);margin-bottom:20rpx;box-shadow:var(--shadow-sm);border:1rpx solid var(--border);transition:all .3s ease}.list-item:active{transform:scale(.98);box-shadow:none}.tag{display:inline-flex;align-items:center;padding:8rpx 20rpx;border-radius:20rpx;font-size:24rpx;font-weight:500;line-height:1}.tag-primary{background:linear-gradient(135deg,#e6f4ff,#bae0ff);color:var(--primary-dark);border:1rpx solid rgba(22,119,255,.2)}.tag-success{background:linear-gradient(135deg,#f6ffed,#d9f7be);color:#389e0d;border:1rpx solid rgba(82,196,26,.2)}.tag-warning{background:linear-gradient(135deg,#fffbe6,#ffe58f);color:#d48806;border:1rpx solid rgba(250,173,20,.2)}.tag-danger{background:linear-gradient(135deg,#fff2f0,#ffccc7);color:#cf1322;border:1rpx solid rgba(255,77,79,.2)}.status-text{display:inline-flex;align-items:center;font-size:24rpx;font-weight:600;padding:8rpx 20rpx;border-radius:20rpx}.status-pending{background:linear-gradient(135deg,#fff7e6,#ffe7ba);color:#d46b08;border:1rpx solid rgba(250,140,22,.2)}.status-processing{background:linear-gradient(135deg,#e6f7ff,#91d5ff);color:var(--primary-dark);border:1rpx solid rgba(22,119,255,.2)}.status-resolved{background:linear-gradient(135deg,#f6ffed,#b7eb8f);color:#389e0d;border:1rpx solid rgba(82,196,26,.2)}.status-closed{background:#f5f5f5;color:#8c8c8c;border:1rpx solid #e8e8e8}.input,.textarea{background:#f8fafc;border:2rpx solid var(--border);border-radius:var(--radius-md);padding:24rpx;font-size:28rpx;color:var(--text-primary);transition:all .3s ease}.input:focus,.textarea:focus{border-color:var(--primary);background:#fff;box-shadow:0 0 0 4rpx rgba(22,119,255,.1)}.gradient-bg{background:linear-gradient(135deg,var(--primary) 0%,var(--primary-light) 100%)}.gradient-bg-success{background:linear-gradient(135deg,#52c41a,#73d13d)}.gradient-bg-warning{background:linear-gradient(135deg,#faad14,#ffc53d)}.gradient-bg-danger{background:linear-gradient(135deg,#ff4d4f,#ff7875)}@keyframes fadeIn{0%{opacity:0;transform:translateY(20rpx)}to{opacity:1;transform:translateY(0)}}.fade-in{animation:fadeIn .4s ease-out}.icon{width:48rpx;height:48rpx;display:inline-flex;align-items:center;justify-content:center}.icon-sm{width:32rpx;height:32rpx}.icon-lg{width:64rpx;height:64rpx}
page{--status-bar-height:25px;--top-window-height:0px;--window-top:0px;--window-bottom:0px;--window-left:0px;--window-right:0px;--window-magin:0px}[data-c-h="true"]{display: none !important;}