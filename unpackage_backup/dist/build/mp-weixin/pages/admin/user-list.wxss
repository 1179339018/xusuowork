.container{min-height:100vh;background:#e6f2ff;display:flex;flex-direction:column}.header{padding:30rpx 40rpx;background:#fff;display:flex;justify-content:space-between;align-items:center;box-shadow:0 2rpx 8rpx rgba(22,119,255,.1);border-bottom:1rpx solid rgba(22,119,255,.1)}.header .title{font-size:34rpx;font-weight:700;color:#333;display:block}.header .subtitle{font-size:26rpx;color:#999}.header .btn-add{background-color:#1677ff;color:#fff;font-size:28rpx;padding:10rpx 30rpx;border-radius:30rpx;line-height:1.5;margin:0}.user-list{flex:1;padding:20rpx}.user-item{background:#fff;padding:30rpx;border-radius:var(--radius-lg);margin-bottom:20rpx;display:flex;justify-content:space-between;align-items:center;box-shadow:0 2rpx 12rpx rgba(22,119,255,.08);border:1rpx solid rgba(22,119,255,.1)}.user-item .user-info{display:flex;align-items:center;flex:1}.user-item .user-info .avatar-placeholder{width:80rpx;height:80rpx;background-color:#e6f7ff;color:#1677ff;border-radius:40rpx;display:flex;align-items:center;justify-content:center;font-size:32rpx;margin-right:20rpx;flex-shrink:0}.user-item .user-info .info-content{flex:1;display:flex;flex-direction:column;justify-content:center}.user-item .user-info .info-content .name{font-size:32rpx;font-weight:700;color:#333;margin-bottom:8rpx}.user-item .user-info .info-content .phone-row{display:flex;align-items:center;margin-bottom:12rpx}.user-item .user-info .info-content .phone-row .phone{font-size:26rpx;color:#666;margin-right:16rpx}.user-item .user-info .info-content .phone-row .bind-status{font-size:20rpx;padding:2rpx 10rpx;background-color:#f5f5f5;color:#999;border-radius:4rpx}.user-item .user-info .info-content .phone-row .bind-status.bound{background-color:#f6ffed;color:#52c41a;border:1rpx solid #b7eb8f}.user-item .user-info .info-content .roles-tag{display:flex;flex-wrap:wrap;gap:10rpx}.user-item .user-info .info-content .roles-tag .tag{font-size:22rpx;color:#1677ff;background-color:#e6f7ff;padding:4rpx 12rpx;border-radius:6rpx}.user-item .action-btn-group{display:flex;gap:20rpx}.user-item .action-btn{padding:10rpx 24rpx;border-radius:8rpx;font-size:26rpx}.user-item .action-btn.edit{background-color:#e6f7ff;color:#1677ff}.user-item .action-btn.unbind{background-color:#fff1f0;color:#ff4d4f}.user-item .action-btn.delete{background-color:#ff4d4f;color:#fff}.user-item .action-btn:active{opacity:.8}.modal-mask{position:fixed;top:0;left:0;right:0;bottom:0;background-color:rgba(0,0,0,.5);display:flex;align-items:center;justify-content:center;z-index:999}.modal-content{width:600rpx;background:#fff;border-radius:var(--radius-xl);padding:40rpx;box-shadow:0 10rpx 40rpx rgba(22,119,255,.2)}.modal-header{margin-bottom:40rpx;text-align:center}.modal-header .modal-title{font-size:34rpx;font-weight:700}.form-item{margin-bottom:30rpx}.form-item .label{display:block;font-size:28rpx;color:#333;margin-bottom:16rpx}.form-item .input{width:100%;height:80rpx;background-color:#f5f7fa;border-radius:8rpx;padding:0 20rpx;box-sizing:border-box;font-size:28rpx}.role-group{display:flex;flex-direction:column;gap:20rpx}.role-group .role-label{display:flex;align-items:center;font-size:28rpx}.role-group .role-label checkbox{transform:scale(.8);margin-right:10rpx}.modal-footer{display:flex;justify-content:space-between;gap:20rpx;margin-top:50rpx}.modal-footer button{flex:1;font-size:30rpx;height:80rpx;line-height:80rpx;border-radius:40rpx;margin:0}.modal-footer button:after{border:none}.modal-footer .btn-cancel{background-color:#f5f5f5;color:#666}.modal-footer .btn-confirm{background-color:#1677ff;color:#fff}
