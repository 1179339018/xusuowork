<view class="container"><view class="header"><view><text class="title">用户授权管理</text><text class="subtitle">共 {{a}} 位用户</text></view><button class="btn-add" bindtap="{{b}}">添加用户</button></view><scroll-view scroll-y class="user-list" enable-back-to-top><view wx:for="{{c}}" wx:for-item="item" wx:key="l" class="user-item fade-in"><view class="user-info"><view class="avatar-placeholder">{{item.a}}</view><view class="info-content"><text class="name">{{item.b}}</text><view class="phone-row"><text class="phone">{{item.c}}</text><text class="{{['bind-status', item.e && 'bound']}}">{{item.d}}</text></view><view class="roles-tag"><text wx:for="{{item.f}}" wx:for-item="role" wx:key="b" class="tag">{{role.a}}</text></view></view></view><view class="action-btn-group"><view class="action-btn edit" bindtap="{{item.g}}"><text>编辑</text></view><view wx:if="{{item.h}}" class="action-btn unbind" bindtap="{{item.i}}"><text>解绑</text></view><view wx:if="{{item.j}}" class="action-btn delete" bindtap="{{item.k}}"><text>删除</text></view></view></view></scroll-view><view wx:if="{{d}}" class="modal-mask" bindtap="{{o}}"><view class="modal-content" catchtap="{{n}}"><view class="modal-header"><text class="modal-title">{{e}}</text></view><view class="form-item"><text class="label">手机号</text><input class="input" placeholder="请输入手机号" type="number" maxlength="11" value="{{f}}" bindinput="{{g}}"/></view><view class="form-item"><text class="label">姓名</text><input class="input" placeholder="请输入姓名" value="{{h}}" bindinput="{{i}}"/></view><view class="form-item"><text class="label">授权角色 (多选)</text><checkbox-group bindchange="{{k}}" class="role-group"><label wx:for="{{j}}" wx:for-item="role" wx:key="d" class="role-label"><checkbox value="{{role.a}}" checked="{{role.b}}" color="#1677ff"/><text>{{role.c}}</text></label></checkbox-group></view><view class="modal-footer"><button class="btn-cancel" bindtap="{{l}}">取消</button><button class="btn-confirm" bindtap="{{m}}">确定</button></view></view></view></view>