.container{min-height:100vh;background:#e6f2ff;padding:32rpx 24rpx 40rpx;display:flex;flex-direction:column;gap:24rpx}.user-card{background:linear-gradient(135deg,var(--primary) 0%,var(--primary-light) 100%);padding:48rpx 40rpx;border-radius:var(--radius-xl);display:flex;align-items:center;box-shadow:var(--shadow-lg);position:relative;overflow:hidden;margin-top:16rpx}.user-card:before{content:"";position:absolute;top:-50%;right:-50%;width:220%;height:220%;background:radial-gradient(circle,rgba(255,255,255,.12) 0%,transparent 70%)}.user-card .avatar{width:120rpx;height:120rpx;background:rgba(255,255,255,.16);-webkit-backdrop-filter:blur(10rpx);backdrop-filter:blur(10rpx);border-radius:60rpx;margin-right:32rpx;display:flex;align-items:center;justify-content:center;border:3rpx solid rgba(255,255,255,.3);position:relative;z-index:1;overflow:hidden}.user-card .avatar .avatar-text{font-size:44rpx;line-height:1;color:#fff}.user-card .avatar .avatar-img{width:100%;height:100%;border-radius:60rpx}.user-card .info{display:flex;flex-direction:column;position:relative;z-index:1;gap:12rpx}.user-card .info .name-row{display:flex;align-items:center;margin-bottom:4rpx}.user-card .info .name-row .name{font-size:38rpx;font-weight:700;color:#fff}.user-card .info .name-row .edit-icon{margin-left:12rpx;font-size:24rpx;opacity:.85}.user-card .info .role-tag{background:rgba(255,255,255,.22);-webkit-backdrop-filter:blur(10rpx);backdrop-filter:blur(10rpx);color:#fff;font-size:24rpx;padding:8rpx 22rpx;border-radius:22rpx;align-self:flex-start;font-weight:600;border:1rpx solid rgba(255,255,255,.3)}.menu-list{background:#fff;border-radius:var(--radius-xl);overflow:hidden;box-shadow:0 4rpx 16rpx rgba(22,119,255,.12);border:1rpx solid rgba(22,119,255,.12)}.menu-list .menu-item{display:flex;align-items:center;padding:32rpx 40rpx;border-bottom:1rpx solid var(--border);transition:all .25s ease}.menu-list .menu-item:last-child{border-bottom:none}.menu-list .menu-item .menu-text{flex:1;font-size:30rpx;color:var(--text-primary);font-weight:500}.menu-list .menu-item .arrow-icon-img{width:32rpx;height:32rpx;margin-left:12rpx;opacity:.6}.menu-list .menu-item:active{background:linear-gradient(90deg,#f0f7ff 0%,transparent 100%);padding-left:44rpx}
