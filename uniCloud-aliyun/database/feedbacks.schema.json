{
	"bsonType": "object",
	"required": ["dispute_id", "type", "result"],
	"properties": {
		"_id": {
			"description": "ID，系统自动生成"
		},
		"dispute_id": {
			"bsonType": "string",
			"description": "纠纷ID",
			"label": "纠纷ID"
		},
		"type": {
			"bsonType": "string",
			"description": "回访方式",
			"enum": ["见面", "电话"],
			"label": "回访方式"
		},
		"method": {
			"bsonType": "string",
			"description": "处理措施",
			"label": "处理措施"
		},
		"result": {
			"bsonType": "string",
			"description": "回访结果",
			"enum": ["已化解", "未化解"],
			"label": "回访结果"
		},
		"notes": {
			"bsonType": "string",
			"description": "备注",
			"label": "备注"
		},
		"media": {
			"bsonType": "array",
			"description": "媒体文件（照片/录音）",
			"items": {
				"bsonType": "object",
				"properties": {
					"type": {
						"bsonType": "string",
						"enum": ["image", "audio"]
					},
					"url": {
						"bsonType": "string"
					}
				}
			}
		},
		"next_date": {
			"bsonType": "timestamp",
			"description": "下次回访日期",
			"label": "下次回访日期"
		},
		"feedback_time": {
			"bsonType": "timestamp",
			"description": "回访时间",
			"label": "回访时间",
			"forceDefaultValue": {
				"$env": "now"
			}
		},
		"feedback_user": {
			"bsonType": "string",
			"description": "回访人openid",
			"label": "回访人"
		}
	}
}
